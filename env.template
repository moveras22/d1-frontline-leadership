# Kit / ConvertKit (Early Access form)
# Create a V4 API key in Kit: Settings → Developer
# Form ID is the numeric ID from Kit (Grow → Forms → your form → Settings),
# not the embed uid (8cf62fc5d2).
KIT_API_KEY=your_kit_v4_api_key
KIT_FORM_ID=your_numeric_form_id

# Google Analytics 4 — Admin → Data Streams → Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity — Settings → Overview → Project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id
